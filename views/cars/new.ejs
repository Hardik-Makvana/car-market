<section class="auth-page sell-car-page">
  <div class="auth-card auth-wide auth-card-enhanced">
    <!-- Icon -->
    <div class="auth-icon-wrapper">
      <div class="auth-icon auth-icon-sell">
        <i class="bi bi-car-front-fill"></i>
      </div>
    </div>

    <!-- TITLE -->
    <h2 class="auth-title" style="font-size: 1.5rem;">Sell Your Car 🚗</h2>
    <p class="auth-subtitle" style="font-size: 0.9rem;">
      Fill the details below to list your car on Ridehub and reach thousands of buyers
    </p>

    <!-- ADD CAR FORM -->
    <form action="/cars" method="POST" class="auth-form-enhanced" enctype="multipart/form-data">
      <!-- CAR BASIC INFO SECTION -->
      <div class="form-section">
        <h3 class="form-section-title" style="font-size: 1.1rem;">
          <i class="bi bi-info-circle"></i> Basic Information
        </h3>
        <div class="auth-grid">
          <!-- CAR NAME -->
          <div class="auth-group">
            <label>
              <i class="bi bi-tag"></i> Car Name
            </label>
            <input
              type="text"
              name="car[carName]"
              placeholder="e.g. Toyota Fortuner"
              required
            />
          </div>

          <!-- PRICE -->
          <div class="auth-group">
            <label>
              <i class="bi bi-currency-rupee"></i> Price (₹)
            </label>
            <input
              type="number"
              name="car[price]"
              placeholder="e.g. 1800000"
              required
              min="0"
            />
          </div>
        </div>
      </div>

      <!-- CAR SPECIFICATIONS SECTION -->
      <div class="form-section">
        <h3 class="form-section-title" style="font-size: 1.1rem;">
          <i class="bi bi-gear"></i> Car Specifications
        </h3>
        <div class="auth-grid">
          <!-- MILEAGE -->
          <div class="auth-group">
            <label>
              <i class="bi bi-speedometer2"></i> Mileage (km)
            </label>
            <input
              type="number"
              name="car[mileage]"
              placeholder="e.g. 45000"
              required
              min="0"
            />
          </div>
          <!-- YEAR -->
          <div class="auth-group">
            <label>
              <i class="bi bi-calendar"></i> Model Year
            </label>
            <input 
              type="number" 
              name="car[year]" 
              placeholder="e.g. 2021"
              min="1990"
              max="<%= new Date().getFullYear() + 1 %>"
              required
            />
          </div>

          <!-- FUEL -->
          <div class="auth-group">
            <label>
              <i class="bi bi-fuel-pump"></i> Fuel Type
            </label>
            <select name="car[fuel]" required>
              <option value="">Select fuel type</option>
              <option>Petrol</option>
              <option>Diesel</option>
              <option>CNG</option>
              <option>Electric</option>
              <option>Hybrid</option>
            </select>
          </div>

          <!-- TRANSMISSION -->
          <div class="auth-group">
            <label>
              <i class="bi bi-gear"></i> Transmission
            </label>
            <select name="car[transmission]" required>
              <option value="">Select transmission</option>
              <option>Manual</option>
              <option>Automatic</option>
              <option>CVT</option>
              <option>AMT</option>
            </select>
          </div>

          <!-- IMAGES (FILE UPLOAD) -->
          <div class="auth-group">
            <label>
              <i class="bi bi-images"></i> Car Photos
            </label>
            <input
              type="file"
              name="images"
              id="images"
              class="form-control"
              multiple
              accept="image/*"
              required
            />
            <small class="form-hint">Upload 2–6 clear photos (front, side, interior, etc.).</small>
          </div>
        </div>
      </div>

      <!-- LOCATION SECTION -->
      <div class="form-section">
        <h3 class="form-section-title" style="font-size: 1.1rem;">
          <i class="bi bi-geo-alt"></i> Location
        </h3>
        <div class="auth-grid">
          <!-- CITY -->
          <div class="auth-group">
            <label>
              <i class="bi bi-building"></i> City
            </label>
            <input 
              type="text" 
              name="car[city]" 
              placeholder="e.g. Rajkot"
              required
            />
          </div>

          <!-- STATE -->
          <div class="auth-group">
            <label>
              <i class="bi bi-map"></i> State
            </label>
            <input 
              type="text" 
              name="car[state]" 
              placeholder="e.g. Gujarat"
              required
            />
          </div>
        </div>
      </div>

      <!-- CONTACT INFORMATION SECTION -->
      <div class="form-section">
        <h3 class="form-section-title" style="font-size: 1.1rem;">
          <i class="bi bi-person-circle"></i> Contact Information
        </h3>
        <div class="auth-grid">
          <div class="auth-group">
            <label>
              <i class="bi bi-person"></i> Owner Name
            </label>
            <input
              type="text"
              name="car[dealerName]"
              placeholder="Your full name"
              required
            />
          </div>

          <div class="auth-group">
            <label>
              <i class="bi bi-telephone"></i> Phone Number
            </label>
            <input
              type="tel"
              name="car[dealerPhone]"
              placeholder="e.g. +91 9876543210"
              required
              pattern="[0-9+\s-]+"
            />
            <small class="form-hint">Buyers will contact you on this number</small>
          </div>
        </div>
      </div>

      <!-- DESCRIPTION SECTION -->
      <div class="form-section">
        <h3 class="form-section-title" style="font-size: 1.1rem;">
          <i class="bi bi-file-text"></i> Description
        </h3>
        <div class="auth-group">
          <label>
            <i class="bi bi-pencil"></i> Car Description
          </label>
          <textarea
            name="car[description]"
            rows="5"
            placeholder="Describe your car in detail: condition, mileage, features, reason for selling, etc..."
          ></textarea>
          <small class="form-hint">A detailed description helps attract more buyers</small>
        </div>
      </div>

      <!-- SUBMIT -->
      <button type="submit" class="auth-btn auth-btn-enhanced auth-btn-sell">
        <i class="bi bi-check-circle"></i> Publish Car Listing
      </button>
    </form>
  </div>
</section>
